{
  "expo": {
    "name": "Ganesapuram",
    "slug": "Ganesapuram",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "வானிலை தகவல் கிடைக்க உங்கள் இருப்பிடம் தேவை."
      }
    },
    "android": {
      "package": "com.ganesapuram.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0D0B14"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "வானிலை தகவல் கிடைக்க உங்கள் இருப்பிடம் தேவை."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "07ef6392-df4d-4474-8bb4-dcec0beb6cbf"
      }
    }
  }
}
